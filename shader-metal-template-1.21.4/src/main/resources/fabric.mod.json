{
	"schemaVersion": 1,
	"id": "shadermetal",
	"version": "${version}",
	"name": "ShaderMetal",
	"description": "A native Metal renderer for Minecraft on Apple Silicon.",
	"authors": [
		"LingXiFox"
	],
	"license": "GPL-3.0-only",
	"icon": "assets/shadermetal/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.example.shadermetal.ShaderMetalClient"
		]
	},
	"mixins": [
		"shadermetal.mixins.json"
	],
	"accessWidener": "shadermetal.accesswidener",
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "1.21.4",
		"java": ">=21",
		"fabric-api": "*"
	}
}
